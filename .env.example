# Next.js (Vercel) — set automatically when using vercel.json buildCommand
# with CONVEX_DEPLOY_KEY; only needed for local dev or manual Vercel builds.
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Convex production secrets (Dashboard → Deployment → Environment Variables)
# bunx convex env set --prod <NAME> <value>

# Magic-link auth (Resend)
AUTH_RESEND_KEY=re_xxxxxxxx
AUTH_EMAIL_FROM=Paul <paul@yourdomain.com>

# Frontend URL for OAuth/magic-link redirects back to the app
SITE_URL=https://your-app.vercel.app

# Match sync (football-data.org)
FOOTBALL_DATA_KEY=xxxxxxxx

# Vercel only — Production Deploy Key from Convex Dashboard → Settings
CONVEX_DEPLOY_KEY=prod:xxxxxxxx
